rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isImage(maxBytes) {
      return request.resource != null &&
        request.resource.size <= maxBytes &&
        request.resource.contentType.matches('image/.*');
    }

    function isVideo(maxBytes) {
      return request.resource != null &&
        request.resource.size <= maxBytes &&
        request.resource.contentType.matches('video/.*');
    }

    // Secure government IDs/Licenses (PII). Only the specific user can read or write their own ID.
    match /license_images/{userId} {
      allow read, write: if isOwner(userId);
    }
    match /license_images/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId);
    }

    match /profile_images/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) && isImage(5 * 1024 * 1024);
    }

    match /profile_photos/{fileName} {
      allow read: if true;
      allow write: if isSignedIn() &&
        fileName == request.auth.uid + ".jpg" &&
        isImage(5 * 1024 * 1024);
    }

    match /portfolio_images/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) && isImage(10 * 1024 * 1024);
    }

    match /portfolio_videos/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) && isVideo(100 * 1024 * 1024);
    }

    match /before_after/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) && isImage(10 * 1024 * 1024);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
