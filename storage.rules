rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Secure government IDs/Licenses (PII). Only the specific user can read or write their own ID.
    match /license_images/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /license_images/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Generic fallback for other assets
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}