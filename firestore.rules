rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User Profile Rules
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      match /favorites/{favoriteId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /bookings/{bookingId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Stylist Profile Rules
    match /stylists/{stylistId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == stylistId; // Allow stylist creation during signup
      allow update, delete: if request.auth != null && request.auth.uid == stylistId;

      match /services/{serviceId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == stylistId;
      }

      match /aiSummary/{summaryId} {
        allow read: if true;
        allow write: if false; // Only Cloud Functions (Admin) should write here
      }
    }

    // Booking Rules
    match /bookings/{bookingId} {
      allow read: if request.auth != null && (
        resource == null ||
        request.auth.uid == resource.data.userId ||
        request.auth.uid == resource.data.stylistId
      );
      // Allow reading bookings to determine availability/stats if you are the stylist
      allow list: if request.auth != null && request.query.limit <= 100 &&
                  (request.query.filters.size() > 0 && request.query.filters[0].op == '==' && request.query.filters[0].field == 'stylistId' && request.query.filters[0].value == request.auth.uid);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        request.auth.uid == resource.data.stylistId
      );
    }

    // Chat Rules
    match /chats/{chatId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // Reviews Rules
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Styles & AI Requests
    match /styles/{styleId} {
      allow read: if true;
      allow write: if false; // System defined
    }

    match /aiStyleRequests/{requestId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    // Default fallback: Deny all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}