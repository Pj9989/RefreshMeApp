rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // â”€â”€â”€ Helper Functions â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isStylist(stylistId) {
      return isAuthenticated() && request.auth.uid == stylistId;
    }

    // â”€â”€â”€ User Profile Rules â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow delete: if isOwner(userId);
      allow update: if isOwner(userId) && (
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isVerified', 'verified']) &&
        (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['verificationStatus']) ||
          request.resource.data.verificationStatus in ['PENDING', 'UNVERIFIED', 'FAILED', 'REQUIRES_INPUT']
        )
      );

      match /favorites/{favoriteId} {
        allow read, write: if isOwner(userId);
      }

      match /bookings/{bookingId} {
        allow read, write: if isOwner(userId);
      }
    }

    // â”€â”€â”€ Stylist Profile Rules â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    match /stylists/{stylistId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.auth.uid == stylistId;
      allow delete: if isStylist(stylistId);
      allow update: if isStylist(stylistId) && (
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'isVerified', 'verified', 'stripeAccountId', 'subscriptionTier',
          'stripeChargesEnabled', 'stripePayoutsEnabled'
        ]) &&
        (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['verificationStatus']) ||
          request.resource.data.verificationStatus in ['PENDING', 'UNVERIFIED', 'FAILED', 'REQUIRES_INPUT']
        )
      );

      match /services/{serviceId} {
        allow read: if true;
        allow write: if isStylist(stylistId);
      }

      match /aiSummary/{summaryId} {
        allow read: if true;
        allow write: if false; // Admin/Cloud Functions only
      }

      // Reviews nested under a stylist — publicly readable, written by reviewer only
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isAuthenticated() && (
          request.auth.uid == request.resource.data.userId ||
          request.auth.uid == request.resource.data.customerId
        );
        allow update, delete: if isAuthenticated() && (
          (resource.data.keys().hasAll(['userId']) && request.auth.uid == resource.data.userId) ||
          (resource.data.keys().hasAll(['customerId']) && request.auth.uid == resource.data.customerId)
        );
      }
    }

    // â”€â”€â”€ Stylist Profiles Collection â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    match /stylistProfiles/{profileId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.auth.uid == profileId;
      allow update, delete: if isAuthenticated() && request.auth.uid == profileId;
    }

    // â”€â”€â”€ Booking Rules â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    match /bookings/{bookingId} {
      allow read: if isAuthenticated() && (
        resource == null ||
        request.auth.uid == resource.data.customerId ||
        request.auth.uid == resource.data.userId ||
        request.auth.uid == resource.data.stylistId
      );
      allow create: if isAuthenticated() && (
        request.auth.uid == request.resource.data.customerId ||
        request.auth.uid == request.resource.data.userId ||
        request.auth.uid == request.resource.data.stylistId
      );
      allow update, delete: if isAuthenticated() && (
        request.auth.uid == resource.data.customerId ||
        request.auth.uid == resource.data.userId ||
        request.auth.uid == resource.data.stylistId
      );
    }

    // â”€â”€â”€ Chat Rules â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    match /chats/{chatId} {
      allow read: if isAuthenticated() && (
        resource == null ||
        request.auth.uid in resource.data.participants
      );
      allow create: if isAuthenticated() &&
        request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() &&
        request.auth.uid in resource.data.participants;
      allow delete: if isAuthenticated() &&
        request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read, write: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // â”€â”€â”€ Reviews Rules â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() &&
        request.auth.uid == request.resource.data.userId;
      allow update, delete: if isAuthenticated() &&
        request.auth.uid == resource.data.userId;
    }

    // â”€â”€â”€ Styles (System Defined) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    match /styles/{styleId} {
      allow read: if true;
      allow write: if false;
    }

    // â”€â”€â”€ AI Style Requests â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    match /aiStyleRequests/{requestId} {
      allow read: if isAuthenticated() && (
        resource == null || request.auth.uid == resource.data.userId
      );
      allow create: if isAuthenticated() &&
        request.auth.uid == request.resource.data.userId;
      allow update, delete: if isAuthenticated() &&
        request.auth.uid == resource.data.userId;
    }

    // â”€â”€â”€ Waitlist Rules â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    match /waitlists/{waitlistId} {
      allow create: if isAuthenticated() &&
        request.auth.uid == request.resource.data.userId;
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.userId ||
        request.auth.uid == resource.data.stylistId
      );
      allow delete: if isAuthenticated() && (
        request.auth.uid == resource.data.userId ||
        request.auth.uid == resource.data.stylistId
      );
    }

    // ─── Legal Acceptances (audit trail) ─────────────────────────────────
    // Tracks click-wrap / e-sign acceptances of ToS, Privacy Policy,
    // Stylist Contractor Agreement, FCRA Consent, At-Home Waiver, etc.
    // Records are owner-scoped and IMMUTABLE once written (no delete).
    match /legalAcceptances/{userId} {
      allow read: if isOwner(userId);
      allow write: if false; // only subcollection docs are written

      match /acceptances/{docKey} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) &&
          request.resource.data.userId == userId &&
          request.resource.data.docKey == docKey &&
          request.resource.data.docVersion is string &&
          request.resource.data.docVersion.size() > 0;
        // Allow re-acceptance (new version) to overwrite prior record
        allow update: if isOwner(userId) &&
          request.resource.data.userId == userId &&
          request.resource.data.docKey == docKey;
        // Audit records must never be deletable
        allow delete: if false;
      }
    }

    // ─── Default: Deny All ───────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
