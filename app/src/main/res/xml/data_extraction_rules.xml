<?xml version="1.0" encoding="utf-8"?>
<!--
    Cloud backup exclusion rules for RefreshMe.

    Sensitive state that must NOT be restored to a different device:
      - fcm_prefs: contains the FCM push token (device-specific, auth-adjacent)
      - prefs:     contains onboarding_completed flag (could skip auth screens on restore)
      - device_id: device-specific identifier

    Anything not listed here is excluded by default because we do NOT use
    a blanket <include domain="sharedpref" path="."/> any more.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude all shared preferences; none contain data worth restoring
             to a new device, and several contain auth/session-adjacent state. -->
        <exclude domain="sharedpref" path="."/>
    </cloud-backup>
    <device-transfer>
        <!-- FCM token and onboarding state are device-specific; exclude them
             from device-to-device transfer as well. -->
        <exclude domain="sharedpref" path="fcm_prefs.xml"/>
        <exclude domain="sharedpref" path="prefs.xml"/>
        <exclude domain="sharedpref" path="device_id.xml"/>
    </device-transfer>
</data-extraction-rules>
