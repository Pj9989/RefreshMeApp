<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <!-- Global actions -->
    <action android:id="@+id/action_global_homeFragment"
        app:destination="@id/homeFragment" />

    <action android:id="@+id/action_global_dashboardFragment"
        app:destination="@id/dashboardFragment" />

    <action android:id="@+id/action_global_stylistListFragment"
        app:destination="@id/stylistListFragment" />

    <!-- Fragment definitions -->
    <fragment
        android:id="@+id/roleSelectFragment"
        android:name="com.refreshme.auth.RoleSelectFragment"
        android:label="Select Role"
        tools:layout="@layout/fragment_role_select" />

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.refreshme.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_details"
            app:destination="@id/stylistDetailsFragment" />
        <action
            android:id="@+id/action_home_to_quiz"
            app:destination="@id/aiStyleQuizFragment" />
    </fragment>

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.refreshme.DashboardFragment"
        android:label="Dashboard">
        <action
            android:id="@+id/action_dashboardFragment_to_mapFragment"
            app:destination="@id/mapFragment" />
        <action
            android:id="@+id/action_dashboard_to_details"
            app:destination="@id/stylistDetailsFragment" />
        <action
            android:id="@+id/action_dashboardFragment_to_virtualTryOnFragment"
            app:destination="@id/virtualTryOnFragment" />
    </fragment>

    <fragment
        android:id="@+id/virtualTryOnFragment"
        android:name="com.refreshme.tryon.VirtualTryOnFragment"
        android:label="Virtual Try-On" />

    <fragment
        android:id="@+id/stylistListFragment"
        android:name="com.refreshme.StylistListFragment"
        android:label="Stylists">
        <argument
            android:name="styleIds"
            app:argType="string[]"
            app:nullable="true"
            android:defaultValue="@null" />
        <action
            android:id="@+id/action_list_to_details"
            app:destination="@id/stylistDetailsFragment" />
    </fragment>

    <fragment
        android:id="@+id/stylistDetailsFragment"
        android:name="com.refreshme.StylistDetailsFragment"
        android:label="Stylist Profile">
        <argument
            android:name="stylistId"
            app:argType="string"
            android:defaultValue="" />

        <deepLink app:uri="https://refreshme-74f79.web.app/stylist/{stylistId}" />
        <deepLink app:uri="refreshme://stylist/{stylistId}" />

        <action
            android:id="@+id/action_details_to_chat"
            app:destination="@id/chatFragment" />
        <action
            android:id="@+id/action_details_to_booking"
            app:destination="@id/bookingFragment" />
    </fragment>

    <fragment
        android:id="@+id/bookingsFragment"
        android:name="com.refreshme.BookingsFragment"
        android:label="My Bookings">
        <action
            android:id="@+id/action_bookings_to_chat"
            app:destination="@id/chatFragment" />
        <action
            android:id="@+id/action_bookings_to_map"
            app:destination="@id/mapFragment" />
        <action
            android:id="@+id/action_bookings_to_liveTracking"
            app:destination="@id/activeMobileBookingFragment" />
    </fragment>

    <fragment
        android:id="@+id/activeMobileBookingFragment"
        android:name="com.refreshme.booking.ActiveMobileBookingFragment"
        android:label="Live Tracking">
        <argument
            android:name="bookingId"
            app:argType="string" />
        <argument
            android:name="isStylist"
            app:argType="boolean"
            android:defaultValue="false" />
    </fragment>

    <fragment
        android:id="@+id/messagesFragment"
        android:name="com.refreshme.chat.CustomerMessagesFragment"
        android:label="Messages">
        <action
            android:id="@+id/action_messages_to_chat"
            app:destination="@id/chatFragment" />
    </fragment>

    <fragment
        android:id="@+id/chatFragment"
        android:name="com.refreshme.chat.ChatFragment"
        android:label="Chat">
        <argument
            android:name="otherUserId"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/mapFragment"
        android:name="com.refreshme.MapFragment"
        android:label="Map">
        <argument
            android:name="stylistId"
            app:argType="string"
            android:defaultValue="" />
    </fragment>

    <fragment
        android:id="@+id/bookingFragment"
        android:name="com.refreshme.BookingFragment"
        android:label="Booking">
        <argument
            android:name="stylistId"
            app:argType="string" />
        <argument
            android:name="serviceName"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null" />
        <argument
            android:name="servicePrice"
            app:argType="float"
            android:defaultValue="0.0" />
    </fragment>

    <fragment
        android:id="@+id/aiStyleQuizFragment"
        android:name="com.refreshme.aistylefinder.AiStyleQuizFragment"
        android:label="AI Style Match">
        <action
            android:id="@+id/action_quiz_to_virtualTryOn"
            app:destination="@id/virtualTryOnFragment" />
    </fragment>

    <fragment
        android:id="@+id/favoritesFragment"
        android:name="com.refreshme.FavoritesFragment"
        android:label="Saved Stylists" />
</navigation>