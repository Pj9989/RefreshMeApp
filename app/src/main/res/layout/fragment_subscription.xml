<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#1C1B1F">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No subscription needed!"
        android:textColor="@android:color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="RefreshMe takes a 10% fee per completed booking. Set up your payout account below to start getting paid."
        android:textColor="#CCCCCC"
        android:textSize="16sp"
        android:textAlignment="center"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/manageSubscriptionButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Set Up Payout Account"
        android:background="@drawable/button_gradient"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:textStyle="bold" />

</LinearLayout>