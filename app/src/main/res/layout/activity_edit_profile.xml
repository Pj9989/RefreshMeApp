<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".profile.EditProfileActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/edit_profile" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- START: Common Fields (Always visible) -->
            <ImageView
                android:id="@+id/profile_image_edit"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginBottom="16dp"
                android:src="@drawable/ic_launcher_background" />

            <Button
                android:id="@+id/upload_image_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="@string/upload_profile_image" />

            <EditText
                android:id="@+id/edit_user_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="@string/user_name"
                android:inputType="textPersonName" />
            <!-- END: Common Fields -->

            <!-- START: Customer Preferences Container (Visible if !isStylist) -->
            <LinearLayout
                android:id="@+id/customer_fields_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:gravity="center_horizontal">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="?android:attr/listDivider" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_my_style_profile"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:layout_marginBottom="16dp"/>

                <!-- Gender Selection -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_gender"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_customer_gender"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:singleSelection="true">
                    <!-- Chips will be added programmatically -->
                </com.google.android.material.chip.ChipGroup>

                <!-- Face Shape Selection -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_my_face_shape"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_customer_face_shape"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:singleSelection="true">
                    <!-- Chips will be added programmatically -->
                </com.google.android.material.chip.ChipGroup>

                <!-- Hair Type Selection -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_my_hair_type"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_customer_hair_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:singleSelection="true">
                    <!-- Chips will be added programmatically -->
                </com.google.android.material.chip.ChipGroup>

                <!-- Vibe Preference -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_preferred_vibe"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_customer_vibe"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:singleSelection="true">
                    <!-- Chips will be added programmatically -->
                </com.google.android.material.chip.ChipGroup>

                <!-- Frequency Selection -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_frequency"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_customer_frequency"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:singleSelection="true">
                    <!-- Chips will be added programmatically -->
                </com.google.android.material.chip.ChipGroup>

                <!-- Finish Preference -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_preferred_finish"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_customer_finish"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:singleSelection="true">
                    <!-- Chips will be added programmatically -->
                </com.google.android.material.chip.ChipGroup>

            </LinearLayout>
            <!-- END: Customer Preferences Container -->

            <!-- START: Stylist-Specific Fields Container (Visible if isStylist) -->
            <LinearLayout
                android:id="@+id/stylist_fields_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:gravity="center_horizontal">

                <!-- Divider before stylist-specific settings -->
                <View
                    android:id="@+id/stylist_divider_top"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="?android:attr/listDivider" />

                <!-- Stylist Section: Bio and Services -->
                <EditText
                    android:id="@+id/edit_stylist_bio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="@string/stylist_bio_hint"
                    android:inputType="textMultiLine"
                    android:lines="4"
                    android:gravity="top|start"
                    android:maxLength="500"
                    android:minLines="3" />

                <!-- Vibe Selection -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Your Vibe (Select all that apply)"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="4dp"/>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_vibes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:singleSelection="false">
                    <!-- Chips will be added programmatically -->
                </com.google.android.material.chip.ChipGroup>

                <!-- Face Shape Specialties -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Face Shape Specialties"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="4dp"/>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_face_shapes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:singleSelection="false">
                    <!-- Chips will be added programmatically -->
                </com.google.android.material.chip.ChipGroup>

                <TextView
                    android:id="@+id/manage_services_link"
                    style="@style/Widget.MaterialComponents.TextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="12dp"
                    android:text="@string/manage_services_pricing"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorPrimary"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground"/>

                <!-- Manage Portfolio Link -->
                <TextView
                    android:id="@+id/manage_portfolio_link"
                    style="@style/Widget.MaterialComponents.TextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="12dp"
                    android:text="@string/manage_portfolio"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorPrimary"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground"/>

                <!-- Manage Payouts Link -->
                <TextView
                    android:id="@+id/manage_payouts_link"
                    style="@style/Widget.MaterialComponents.TextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="12dp"
                    android:text="@string/manage_payouts"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorPrimary"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground"/>

                <!-- Location and Availability Header -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="8dp"
                    android:text="@string/location_and_availability"
                    android:textAppearance="?attr/textAppearanceTitleMedium"/>

                <!-- Service Location Type Selector -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/service_location_type"
                    android:textAppearance="?attr/textAppearanceBodyMedium"/>

                <RadioGroup
                    android:id="@+id/radio_location_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">
                    <RadioButton
                        android:id="@+id/radio_fixed_location"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/location_fixed" />
                    <RadioButton
                        android:id="@+id/radio_mobile_location"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/location_mobile" />
                </RadioGroup>

                <!-- Fixed Location Field (Visible if radio_fixed_location is checked) -->
                <EditText
                    android:id="@+id/edit_salon_address"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="@string/salon_address_hint"
                    android:inputType="textPostalAddress"
                    android:visibility="gone" />

                <!-- Mobile Location Field (Visible if radio_mobile_location is checked) -->
                <EditText
                    android:id="@+id/edit_service_radius"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="@string/service_radius_hint"
                    android:inputType="number"
                    android:maxLength="3"
                    android:visibility="gone" />

                <!-- Manage Working Hours Link -->
                <TextView
                    android:id="@+id/manage_hours_link"
                    style="@style/Widget.MaterialComponents.TextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="12dp"
                    android:text="@string/manage_working_hours"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorPrimary"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground"/>


                <!-- Stylist Verification Fields -->
                <TextView
                    android:id="@+id/verification_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:text="@string/verification_header_stylist"
                    android:textAppearance="?attr/textAppearanceTitleMedium" />

                <ImageView
                    android:id="@+id/license_image_preview"
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:layout_marginTop="16dp"
                    android:scaleType="centerCrop"
                    android:background="#EEE"
                    android:contentDescription="@string/license_id_preview" />

                <Button
                    android:id="@+id/upload_license_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/upload_license_id" />

                <TextView
                    android:id="@+id/verification_status_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    tools:text="Status: Pending Review" />
            </LinearLayout>
            <!-- END: Stylist-Specific Fields Container -->


            <!-- Identity Verification Section (Stylist Only) -->
            <LinearLayout
                android:id="@+id/identity_verification_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="24dp"
                    android:background="?android:attr/listDivider" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Identity Verification"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:layout_marginBottom="8dp"/>

                <Button
                    android:id="@+id/stripe_verify_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Verify Identity with Stripe"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/stripe_verification_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:text="Status: Unverified" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="24dp"
                android:background="?android:attr/listDivider" />

            <Button
                android:id="@+id/save_profile_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/save" />
        </LinearLayout>
    </ScrollView>

</LinearLayout>