<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".profile.EditProfileActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/edit_profile" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:id="@+id/main_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?android:attr/windowBackground">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Common Profile Header -->
            <FrameLayout
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_marginBottom="16dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/profile_image_edit"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_launcher_background"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.App.CircleImageView" />

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/upload_image_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="10dp"
                    android:layout_marginBottom="10dp"
                    app:fabSize="mini"
                    app:srcCompat="@drawable/ic_star_24dp"
                    app:tint="@color/gold"
                    app:backgroundTint="@color/black"
                    android:contentDescription="@string/upload_profile_image" />
            </FrameLayout>

            <EditText
                android:id="@+id/edit_user_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:gravity="center"
                android:hint="@string/user_name"
                android:inputType="textPersonName"
                android:textSize="22sp"
                android:textStyle="bold"
                android:background="@android:color/transparent" />


            <!-- START: CUSTOMER UI -->
            <LinearLayout
                android:id="@+id/customer_fields_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="STYLE DISCOVERY"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:textColor="@color/gold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="16dp"
                    android:gravity="center"/>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#EEE"
                    app:cardBackgroundColor="#FDFDFD">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <TextView android:text="@string/label_gender" android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" />
                        <com.google.android.material.chip.ChipGroup android:id="@+id/chip_group_customer_gender" android:layout_width="match_parent" android:layout_height="wrap_content" app:singleSelection="true" android:layout_marginBottom="20dp" />

                        <TextView android:text="@string/label_my_face_shape" android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" />
                        <com.google.android.material.chip.ChipGroup android:id="@+id/chip_group_customer_face_shape" android:layout_width="match_parent" android:layout_height="wrap_content" app:singleSelection="true" android:layout_marginBottom="20dp" />

                        <TextView android:text="@string/label_my_hair_type" android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" />
                        <com.google.android.material.chip.ChipGroup android:id="@+id/chip_group_customer_hair_type" android:layout_width="match_parent" android:layout_height="wrap_content" app:singleSelection="true" android:layout_marginBottom="20dp" />

                        <TextView android:text="@string/label_preferred_vibe" android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" />
                        <com.google.android.material.chip.ChipGroup android:id="@+id/chip_group_customer_vibe" android:layout_width="match_parent" android:layout_height="wrap_content" app:singleSelection="true" android:layout_marginBottom="20dp" />

                        <TextView android:text="@string/label_frequency" android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" />
                        <com.google.android.material.chip.ChipGroup android:id="@+id/chip_group_customer_frequency" android:layout_width="match_parent" android:layout_height="wrap_content" app:singleSelection="true" android:layout_marginBottom="20dp" />

                        <TextView android:text="@string/label_preferred_finish" android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" />
                        <com.google.android.material.chip.ChipGroup android:id="@+id/chip_group_customer_finish" android:layout_width="match_parent" android:layout_height="wrap_content" app:singleSelection="true" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
            <!-- END: CUSTOMER UI -->


            <!-- START: STYLIST UI -->
            <LinearLayout
                android:id="@+id/stylist_fields_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="PROFESSIONAL DASHBOARD"
                    android:textAppearance="?attr/textAppearanceTitleLarge"
                    android:textColor="?attr/colorPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="24dp"/>

                <!-- Professional Bio Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="16dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                        <TextView android:text="Professional Bio" android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" />
                        <EditText android:id="@+id/edit_stylist_bio" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="@string/stylist_bio_hint" android:inputType="textMultiLine" android:lines="4" android:gravity="top" android:background="@drawable/edit_text_background" android:padding="12dp" />
                        <Button android:id="@+id/btn_ai_bio" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="end" android:text="AI Generate Bio" app:icon="@drawable/ic_star_24dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Social Links Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="16dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                        <TextView android:text="Online Presence" android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" />
                        <EditText android:id="@+id/edit_stylist_instagram" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Instagram @username" android:inputType="text" android:layout_marginBottom="8dp" />
                        <EditText android:id="@+id/edit_stylist_tiktok" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="TikTok @username" android:inputType="text" android:layout_marginBottom="8dp" />
                        <EditText android:id="@+id/edit_stylist_website" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Website / Portfolio Link" android:inputType="textUri" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Manage Links Section -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="16dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="8dp">
                        <TextView android:id="@+id/manage_services_link" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="14dp" android:text="@string/manage_services_pricing" android:drawableStart="@drawable/ic_cut_black_24dp" android:drawablePadding="16dp" android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground" />
                        <TextView android:id="@+id/manage_portfolio_link" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="14dp" android:text="@string/manage_portfolio" android:drawableStart="@drawable/ic_profile" android:drawablePadding="16dp" android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground" />
                        <TextView android:id="@+id/manage_payouts_link" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="14dp" android:text="@string/manage_payouts" android:drawableStart="@drawable/ic_subscription" android:drawablePadding="16dp" android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground" />
                        <TextView android:id="@+id/manage_hours_link" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="14dp" android:text="@string/manage_working_hours" android:drawableStart="@drawable/ic_baseline_access_time_24" android:drawablePadding="16dp" android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Location & Availability -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="16dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                        <TextView android:text="Service Location" android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" />
                        <RadioGroup android:id="@+id/radio_location_type" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                            <RadioButton android:id="@+id/radio_fixed_location" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/location_fixed" />
                            <RadioButton android:id="@+id/radio_mobile_location" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/location_mobile" />
                        </RadioGroup>
                        <EditText android:id="@+id/edit_salon_address" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="@string/salon_address_hint" android:inputType="textPostalAddress" android:visibility="gone" android:layout_marginTop="8dp" />
                        <EditText android:id="@+id/edit_service_radius" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="@string/service_radius_hint" android:inputType="number" android:visibility="gone" android:layout_marginTop="8dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Verification Section -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="16dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                        <TextView android:text="License &amp; Identity" android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" />
                        <ImageView android:id="@+id/license_image_preview" android:layout_width="match_parent" android:layout_height="180dp" android:scaleType="centerCrop" android:background="#F5F5F5" />
                        <Button android:id="@+id/upload_license_button" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Update License" />
                        <TextView android:id="@+id/verification_status_text" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:gravity="center" />

                        <LinearLayout android:id="@+id/identity_verification_container" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginTop="16dp" android:visibility="gone">
                            <Button android:id="@+id/stripe_verify_button" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Verify with Stripe" />
                            <TextView android:id="@+id/stripe_verification_status" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
            <!-- END: STYLIST UI -->


            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="32dp"
                android:background="?android:attr/listDivider" />

            <Button
                android:id="@+id/save_profile_button"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="SAVE CHANGES"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="30dp" />

            <TextView
                android:id="@+id/security_footer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:text="Securely managed by RefreshMe."
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>