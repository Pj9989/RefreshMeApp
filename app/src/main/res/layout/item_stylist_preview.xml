<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="@color/stylist_card_background"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <FrameLayout
            android:id="@+id/image_container"
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/stylist_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_rounded_image"
                tools:src="@tools:sample/avatars" />

            <TextView
                android:id="@+id/flash_deal_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/red"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="FLASH"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="-4dp"
                android:visibility="gone"
                tools:visibility="visible"/>
        </FrameLayout>

        <LinearLayout
            android:id="@+id/stylist_info_layout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            app:layout_constraintStart_toEndOf="@+id/image_container"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/stylist_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stylist Name"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@color/white"
                tools:text="Alex Rivera"/>

            <TextView
                android:id="@+id/stylist_service"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Service Name"
                android:textSize="13sp"
                android:textColor="@color/gray"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Master Barber"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_star_filled_24dp"
                    app:tint="@color/gold"/>

                <TextView
                    android:id="@+id/stylist_rating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="4.9"
                    android:textSize="12sp"
                    android:textColor="@color/white"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/stylist_distance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="1.2 mi"
                    android:textSize="12sp"
                    android:textColor="@color/gray"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/tvMatchBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/chip_background"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:text="95% Match"
                    android:textColor="@color/green"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:visibility="visible"/>

                <TextView
                    android:id="@+id/tvVibeBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/chip_background"
                    android:backgroundTint="#33FFFFFF"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:text="Urban"
                    android:textColor="@color/light_gray"
                    android:textSize="10sp"
                    android:visibility="gone"
                    tools:visibility="visible"/>
            </LinearLayout>

        </LinearLayout>

        <TextView
            android:id="@+id/tvMatchExplanation"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/chip_background"
            android:backgroundTint="#1AFFFFFF"
            android:padding="8dp"
            android:text="Expert in the clean fades you're looking for."
            android:textSize="11sp"
            android:textColor="@color/light_gray"
            android:fontStyle="italic"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/image_container"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:visibility="visible"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>