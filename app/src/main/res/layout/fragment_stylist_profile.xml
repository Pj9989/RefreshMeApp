<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".stylist.StylistProfileFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stylist Profile"
            android:textAppearance="?attr/textAppearanceHeadline5"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_marginBottom="16dp"/>

        <!-- Online Toggle -->
        <Switch
            android:id="@+id/onlineToggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Go Online"
            android:textSize="18sp"
            android:textColor="?android:attr/textColorPrimary"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            tools:checked="true"/>

        <!-- Edit Profile -->
        <TextView
            android:id="@+id/editProfileText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Edit Profile"
            android:textSize="16sp"
            android:textColor="?android:attr/textColorPrimary"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"/>

        <!-- ADDED: Trial Status Banner -->
        <TextView
            android:id="@+id/trialStatusTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/green"
            android:visibility="gone"
            tools:text="Free Trial: 29 Days Remaining"
            tools:visibility="visible"/>

        <!-- Manage Subscription -->
        <TextView
            android:id="@+id/manageSubscriptionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Manage Subscription"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"/>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:background="?android:attr/textColorSecondary"/>

        <!-- Support & Legal Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Support &amp; Legal"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_marginTop="8dp"/>

        <!-- NEW: Help Center -->
        <TextView
            android:id="@+id/helpCenterText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Help Center"
            android:textSize="16sp"
            android:textColor="?android:attr/textColorPrimary"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"/>

        <!-- NEW: About RefreshMe -->
        <TextView
            android:id="@+id/aboutText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="About RefreshMe"
            android:textSize="16sp"
            android:textColor="?android:attr/textColorPrimary"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"/>

        <!-- Privacy Policy -->
        <TextView
            android:id="@+id/privacyPolicyText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Privacy Policy"
            android:textSize="16sp"
            android:textColor="?android:attr/textColorPrimary"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"/>

        <!-- Sign Out -->
        <TextView
            android:id="@+id/signOutButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sign Out"
            android:textSize="16sp"
            android:textColor="?android:attr/textColorPrimary"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>