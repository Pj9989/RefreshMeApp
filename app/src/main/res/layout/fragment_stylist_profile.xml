<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".stylist.StylistProfileFragment">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Stylist Profile"
        android:textAppearance="?attr/textAppearanceHeadline5"
        android:layout_marginBottom="16dp"/>

    <!-- Identity Verification Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Identity Verification"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/verificationStatusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Identity Not Verified"
                android:textSize="14sp"
                android:textColor="@android:color/darker_gray"
                android:layout_marginBottom="12dp"
                tools:text="Identity Verified ✓" />

            <Button
                android:id="@+id/verifyIdentityButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Verify Identity"
                android:visibility="visible" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Online / Offline Toggle -->
    <Switch
        android:id="@+id/onlineToggle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Go Online"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:textSize="18sp"
        android:layout_marginTop="8dp"
        tools:checked="true" />

    <!-- Other profile details will go here -->

</LinearLayout>