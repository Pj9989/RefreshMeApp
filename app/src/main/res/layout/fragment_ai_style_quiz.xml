<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".aistylefinder.AiStyleQuizFragment">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@+id/btnScanFace"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Who are you finding a style for?"
                android:textAppearance="?attr/textAppearanceHeadline6" />

            <RadioGroup
                android:id="@+id/rgGender"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <RadioButton
                    android:id="@+id/rbGenderWomen"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Women" />

                <RadioButton
                    android:id="@+id/rbGenderMen"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Men" />
            </RadioGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="What vibe do you want?"
                android:textAppearance="?attr/textAppearanceHeadline6" />

            <RadioGroup
                android:id="@+id/rgVibe"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <RadioButton
                    android:id="@+id/rbVibeClean"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Clean &amp; classic" />

                <RadioButton
                    android:id="@+id/rbVibeBold"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Bold &amp; trendy" />

                <RadioButton
                    android:id="@+id/rbVibeLow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Low maintenance" />
            </RadioGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="How often do you want to get a cut?"
                android:textAppearance="?attr/textAppearanceHeadline6" />

            <RadioGroup
                android:id="@+id/rgFrequency"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <RadioButton
                    android:id="@+id/rbFreqWeekly"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Weekly" />

                <RadioButton
                    android:id="@+id/rbFreqBiWeekly"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Every 2 weeks" />

                <RadioButton
                    android:id="@+id/rbFreqMonthly"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Monthly" />
            </RadioGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="What finish do you like?"
                android:textAppearance="?attr/textAppearanceHeadline6" />

            <RadioGroup
                android:id="@+id/rgFinish"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <RadioButton
                    android:id="@+id/rbFinishNatural"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Natural look" />

                <RadioButton
                    android:id="@+id/rbFinishSharp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sharp line-up" />

                <RadioButton
                    android:id="@+id/rbFinishNew"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Try something new" />
            </RadioGroup>

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnScanFace"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:text="Scan Face for Precision (Optional)"
        app:icon="@drawable/ic_style_finder"
        app:layout_constraintBottom_toTopOf="@+id/btnSubmit"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSubmit"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="Get Recommendations"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>